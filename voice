def cmd_transcribe(args):
    """Transcribir archivo específico"""
    if not args.file:
        print("Error: Especifica un archivo")
        print("Uso: voice transcribe <archivo.wav>")
        return

    if not os.path.exists(args.file):
        print(f"Error: Archivo no encontrado: {args.file}")
        return

    # Inicializar transcriptor
    model = getattr(args, 'model', 'base')
    language = getattr(args, 'language', 'es')

    transcriber = AudioTranscriber(model_name=model, default_language=language)

    print(f"Transcribiendo: {args.file}")
    result = transcriber.transcribe_file(args.file, language=language)

    if result and result["text"]:
        print("\nTranscripción:")
        print("-" * 50)
        print(result["text"])
        print("-" * 50)
        print(f"Idioma: {result['language']}")
        print(f"Tiempo: {result['transcription_time']:.2f}s")

        # Copiar al portapapeles si está disponible
        if CLIPBOARD_AVAILABLE:
            try:
                pyperclip.copy(result["text"])
                print("Texto copiado al portapapeles")
            except:
                pass
    else:
        print("Error: No se pudo transcribir el archivo")

def cmd_batch(args):
    """Transcribir lote de archivos"""
    if not args.directory:
        print("Error: Especifica un directorio")
        print("Uso: voice batch <directorio>")
        return

    directory = Path(args.directory)
    if not directory.exists() or not directory.is_dir():
        print(f"Error: Directorio no válido: {directory}")
        return

    # Buscar archivos de audio
    audio_extensions = ['.wav', '.mp3', '.m4a', '.flac', '.aac']
    audio_files = []

    for ext in audio_extensions:
        audio_files.extend(directory.glob(f"*{ext}"))

    if not audio_files:
        print(f"Error: No se encontraron archivos de audio en: {directory}")
        return

    # Inicializar transcriptor
    model = getattr(args, 'model', 'base')
    language = getattr(args, 'language', 'es')

    transcriber = AudioTranscriber(model_name=model, default_language=language)

    print(f"Transcribiendo {len(audio_files)} archivos...")

    results = []
    for i, file_path in enumerate(audio_files, 1):
        print(f"\n[{i}/{len(audio_files)}] {file_path.name}")

        try:
            result = transcriber.transcribe_file(str(file_path), language=language)
            if result and result["text"]:
                results.append({
                    'file': file_path.name,
                    'text': result['text'],
                    'language': result['language']
                })
                print(f"  Texto: {result['text'][:100]}...")
            else:
                print("  Error en transcripción")
        except Exception as e:
            print(f"  Error: {e}")

    # Guardar resumen
    if results:
        summary_file = directory / "transcription_summary.txt"
        with open(summary_file, "w", encoding="utf-8") as f:
            f.write("TRANSCRIPCIÓN POR LOTES\n")
            f.write("=" * 50 + "\n\n")

            for result in results:
                f.write(f"Archivo: {result['file']}\n")
                f.write(f"Idioma: {result['language']}\n")
                f.write(f"Texto: {result['text']}\n")
                f.write("-" * 40 + "\n\n")

        print(f"\nResumen guardado en: {summary_file}")
        print(f"Transcripciones exitosas: {len(results)}/{len(audio_files)}")

def cmd_devices(args):
    """Listar dispositivos de audio"""
    import sounddevice as sd

    print("Dispositivos de audio disponibles:")
    print("-" * 50)

    devices = sd.query_devices()
    for i, device in enumerate(devices):
        device_type = []
        if device['max_input_channels'] > 0:
            device_type.append('INPUT')
        if device['max_output_channels'] > 0:
            device_type.append('OUTPUT')

        default_mark = " (DEFAULT)" if i == sd.default.device[0] else ""
        print(f"  {i}: {device['name']}")
        print(f"     Tipo: {'/'.join(device_type)}{default_mark}")
        print(f"     Sample rate: {device['default_samplerate']} Hz")
        print()

def cmd_record(args):
    """Grabación directa con duración específica"""
    # Aplicar configuración guardada
    apply_audio_config()

    import sounddevice as sd
    import numpy as np
    from scipy.io.wavfile import write
    import time

    duration = getattr(args, 'duration', 10)  # 10 segundos por defecto

    # Obtener configuración
    config = load_config()
    device_id = config.get("device_id")

    if device_id is not None:
        print(f"Usando dispositivo configurado: {device_id}")
    else:
        print("Usando dispositivo por defecto")

    print(f"Grabando por {duration} segundos...")

    try:
        # Grabación directa
        sample_rate = 44100
        audio_data = sd.rec(
            int(duration * sample_rate),
            samplerate=sample_rate,
            channels=1,
            device=device_id,
            dtype='float64'
        )

        print("GRABANDO... Habla ahora!")
        sd.wait()

        # Verificar y guardar
        max_level = np.max(np.abs(audio_data))
        if max_level > 0.001:
            print(f"Audio grabado (nivel: {max_level:.3f})")

            # Guardar archivo
            timestamp = int(time.time())
            filename = f"voice_record_{timestamp}.wav"

            recordings_dir = Path("recordings")
            recordings_dir.mkdir(exist_ok=True)
            filepath = recordings_dir / filename

            audio_normalized = np.clip(audio_data * 32767, -32768, 32767).astype(np.int16)
            write(str(filepath), sample_rate, audio_normalized)

            print(f"Archivo guardado: {filepath}")

            # Auto-transcribir si se especifica
            if getattr(args, 'transcribe', False):
                print("\nTranscribiendo automáticamente...")
                # Simular args para transcribe
                class TranscribeArgs:
                    def __init__(self, file):
                        self.file = file
                        self.model = getattr(args, 'model', 'base')
                        self.language = getattr(args, 'language', 'es')

                cmd_transcribe(TranscribeArgs(str(filepath)))
        else:
            print("Error: No se detectó audio")
            print("Verifica la configuración del dispositivo:")
            print("1. voice devices  # Ver dispositivos")
            print("2. voice device <id>  # Cambiar dispositivo")
            print("3. voice test  # Probar dispositivo")

    except Exception as e:
        print(f"Error durante grabación: {e}")
        print("Verifica la configuración del dispositivo con: voice test")

def cmd_device(args):
    """Cambiar dispositivo de audio"""
    if not hasattr(args, 'device_id') or args.device_id is None:
        # Mostrar dispositivos actuales
        config = load_config()
        print(f"Dispositivo configurado: {config['device_id']}")
        print("\nDispositivos disponibles:")
        cmd_devices(args)
        return

    import sounddevice as sd

    try:
        device_id = int(args.device_id)
        device_info = sd.query_devices(device_id)

        if device_info['max_input_channels'] == 0:
            print(f"Error: El dispositivo {device_id} no es de entrada")
            return

        # Cambiar dispositivo por defecto
        sd.default.device[0] = device_id

        # Guardar configuración
        config = load_config()
        config["device_id"] = device_id
        if save_config(config):
            print(f"Dispositivo cambiado y guardado: {device_info['name']}")
        else:
            print(f"Dispositivo cambiado (solo esta sesión): {device_info['name']}")

        print(f"ID: {device_id}")
        print(f"Canales: {device_info['max_input_channels']}")
        print(f"Sample rate: {device_info['default_samplerate']} Hz")

    except ValueError:
        print("Error: ID de dispositivo debe ser un número")
    except Exception as e:
        print(f"Error configurando dispositivo: {e}")

def cmd_test(args):
    """Probar dispositivo de audio"""
    import sounddevice as sd
    import numpy as np

    # Aplicar configuración guardada
    apply_audio_config()

    device_id = getattr(args, 'device_id', None)

    if device_id is not None:
        try:
            device_id = int(device_id)
        except ValueError:
            print("Error: ID de dispositivo debe ser un número")
            return
    else:
        # Usar dispositivo configurado o por defecto
        config = load_config()
        if config["device_id"] is not None:
            device_id = config["device_id"]
            print(f"Usando dispositivo configurado: {device_id}")
        else:
            device_id = sd.default.device[0]
            print(f"Usando dispositivo por defecto: {device_id}")

    try:
        device_info = sd.query_devices(device_id)
        print(f"Probando dispositivo {device_id}: {device_info['name']}")
        print(f"Canales entrada: {device_info['max_input_channels']}")
        print(f"Sample rate: {device_info['default_samplerate']} Hz")

        if device_info['max_input_channels'] == 0:
            print("Error: Este dispositivo no tiene entrada de audio")
            return

        # Probar grabación corta
        print("Probando grabación por 2 segundos... ¡HABLA AHORA!")

        test_data = []
        def test_callback(indata, frames, time, status):
            test_data.append(indata.copy())

        with sd.InputStream(
            device=device_id,
            samplerate=int(device_info['default_samplerate']),
            channels=1,
            callback=test_callback,
            blocksize=1024,
            dtype=np.float32
        ):
            sd.sleep(2000)  # 2 segundos

        if test_data:
            audio_data = np.concatenate(test_data)
            max_level = np.max(np.abs(audio_data))
            rms_level = np.sqrt(np.mean(audio_data ** 2))

            print(f"Nivel máximo: {max_level:.4f}")
            print(f"Nivel RMS: {rms_level:.4f}")

            if max_level > 0.001:
                print("✓ DISPOSITIVO FUNCIONAL - Audio detectado correctamente")
                silence_percentage = (np.sum(np.abs(audio_data) < 0.001) / len(audio_data)) * 100
                print(f"Contenido de voz: {100-silence_percentage:.1f}%")
            else:
                print("❌ No se detectó audio")
                print("- Verifica que el micrófono esté conectado")
                print("- Aumenta el volumen del micrófono")
                print("- Habla más cerca del micrófono")
        else:
            print("❌ No se recibieron datos de audio")

    except Exception as e:
        print(f"Error probando dispositivo: {e}")

