def cmd_version(args=None):
    """Mostrar versión"""
    print("Voice CLI v1.0")
    print("Transcripción de audio con OpenAI Whisper")

def main():
    """Función principal del comando global"""

    # Parser principal
    parser = argparse.ArgumentParser(
        prog='voice',
        description='Voice CLI - Transcripción de audio con Whisper',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )

    # Argumentos globales
    parser.add_argument('--model', '-m', default='base',
                       choices=['tiny', 'base', 'small', 'medium', 'large'],
                       help='Modelo de Whisper (default: base)')

    parser.add_argument('--language', '-l', default='es',
                       help='Idioma para transcripción (default: es)')

    parser.add_argument('--sample-rate', '-sr', type=int, default=44100,
                       help='Frecuencia de muestreo (default: 44100)')

    # Subcomandos
    subparsers = parser.add_subparsers(dest='command', help='Comandos disponibles')

    # Comando transcribe
    transcribe_parser = subparsers.add_parser('transcribe', help='Transcribir archivo')
    transcribe_parser.add_argument('file', help='Archivo de audio a transcribir')

    # Comando batch
    batch_parser = subparsers.add_parser('batch', help='Transcribir lote')
    batch_parser.add_argument('directory', help='Directorio con archivos de audio')

    # Comando record
    record_parser = subparsers.add_parser('record', help='Grabación con duración')
    record_parser.add_argument('--duration', '-d', type=int, default=10,
                              help='Duración en segundos (default: 10)')
    record_parser.add_argument('--transcribe', '-t', action='store_true',
                              help='Transcribir automáticamente después de grabar')

    # Comando device
    device_parser = subparsers.add_parser('device', help='Cambiar dispositivo de audio')
    device_parser.add_argument('device_id', nargs='?', type=int,
                              help='ID del dispositivo (sin ID muestra lista)')

    # Comando test
    test_parser = subparsers.add_parser('test', help='Probar dispositivo de audio')
    test_parser.add_argument('device_id', nargs='?', type=int,
                            help='ID del dispositivo a probar (opcional)')

    # Comando language
    language_parser = subparsers.add_parser('language', help='Configurar idioma')
    language_parser.add_argument('language_code', nargs='?',
                                help='Código de idioma (es, en, fr, etc.)')

    # Comando sample-rate
    rate_parser = subparsers.add_parser('sample-rate', help='Configurar sample rate')
    rate_parser.add_argument('rate', nargs='?', type=int,
                            help='Frecuencia en Hz (ej: 48000)')

    # Comando start-debug
    subparsers.add_parser('start-debug', help='Grabación con información detallada')

    # Comandos simples
    subparsers.add_parser('start', help='Iniciar grabación (modo limpio)')
    subparsers.add_parser('stop', help='Detener grabación (solo modo interactivo)')
    subparsers.add_parser('devices', help='Listar dispositivos de audio')
    subparsers.add_parser('config', help='Mostrar configuración')
    subparsers.add_parser('install', help='Información de instalación')
    subparsers.add_parser('help', help='Mostrar ayuda detallada')
    subparsers.add_parser('version', help='Mostrar versión')

    # Parse de argumentos
    args = parser.parse_args()

    # Mapeo de comandos
    commands = {
        'transcribe': cmd_transcribe,
        'batch': cmd_batch,
        'record': cmd_record,
        'start': cmd_start,
        'start-debug': cmd_start_debug,
        'stop': cmd_stop,
        'device': cmd_device,
        'test': cmd_test,
        'language': cmd_language,
        'sample-rate': cmd_sample_rate,
        'reset-config': cmd_reset_config,
        'devices': cmd_devices,
        'config': cmd_config,
        'install': cmd_install,
        'help': cmd_help,
        'version': cmd_version,
    }

    # Ejecutar comando
    if args.command in commands:
        try:
            commands[args.command](args)
        except KeyboardInterrupt:
            print("\nOperación cancelada por el usuario")
        except Exception as e:
            print(f"Error: {e}")
            sys.exit(1)
    else:
        # Sin comando o comando no reconocido = modo interactivo
        if args.command is None:
            cmd_interactive()
        else:
            print(f"Comando desconocido: {args.command}")
            cmd_help()
            sys.exit(1)

if __name__ == "__main__":
    main()