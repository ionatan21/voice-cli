def load_config():
    """Carga configuración persistente"""
    default_config = {
        "device_id": None,
        "sample_rate": 44100,
        "language": "es",
        "model": "base"
    }

    try:
        if CONFIG_FILE.exists():
            import json
            with open(CONFIG_FILE, 'r', encoding='utf-8') as f:
                config = json.load(f)
                return {**default_config, **config}
    except Exception:
        pass

    return default_config

def save_config(config):
    """Guarda configuración persistente"""
    try:
        import json
        with open(CONFIG_FILE, 'w', encoding='utf-8') as f:
            json.dump(config, f, indent=2, ensure_ascii=False)
        return True
    except Exception:
        return False

def apply_audio_config():
    """Aplica configuración de audio guardada"""
