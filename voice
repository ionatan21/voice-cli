def cmd_start(args):
    """Iniciar grabación (versión limpia)"""
    # Aplicar configuración guardada
    apply_audio_config()

    import sounddevice as sd
    import numpy as np
    from scipy.io.wavfile import write
    import threading
    import time
    from pathlib import Path
    import whisper
    import os

    print("Iniciando grabación...")

    config = load_config()
    model_name = config.get('model', 'base')
    language = config.get('language', 'es')

    # Variables de grabación
    recording = False
    audio_data = []
    sample_rate = 44100

    # Crear directorio de grabaciones
    recordings_dir = Path("recordings")
    recordings_dir.mkdir(exist_ok=True)

    def audio_callback(indata, frames, time, status):
        nonlocal audio_data
        if recording:
            if indata.dtype != np.float32:
                if indata.dtype == np.int16:
                    processed_data = indata.astype(np.float32) / 32768.0
                else:
                    processed_data = indata.astype(np.float32)
            else:
                processed_data = indata
            audio_data.append(processed_data.copy())

    def start_recording():
        nonlocal recording, audio_data, sample_rate
        try:
            current_device = sd.default.device[0] if sd.default.device[0] is not None else 0
            device_info = sd.query_devices(current_device)
            device_sample_rate = int(device_info['default_samplerate'])
            sample_rate = device_sample_rate
        except:
            pass

        recording = True
        audio_data = []

        # Intentar configuraciones
        configs = [(sample_rate, np.float32), (44100, np.float32), (48000, np.float32)]

        for sr, dtype in configs:
            try:
                stream = sd.InputStream(
                    samplerate=sr,
                    channels=1,
                    callback=audio_callback,
                    blocksize=1024,
                    dtype=dtype
                )
                stream.start()
                sample_rate = sr
                return stream
            except:
                continue
        return None

    def stop_recording_and_save(stream):
        nonlocal recording, audio_data
        recording = False
        if stream:
            stream.stop()
            stream.close()

        if not audio_data:
            return None

        audio_array = np.concatenate(audio_data, axis=0)
        timestamp = int(time.time())
        filename = f"recording_{timestamp}.wav"
        filepath = recordings_dir / filename

        audio_array = np.clip(audio_array, -1.0, 1.0)
        audio_normalized = (audio_array * 32767).astype(np.int16)

        try:
            write(str(filepath), sample_rate, audio_normalized)
            return str(filepath)
        except:
            return None

    def transcribe_clean(audio_file):
        try:
            # Cargar modelo silenciosamente
            model = whisper.load_model(model_name)

            result = model.transcribe(
                audio_file,
                language=language,
                verbose=False
            )

            text = result["text"].strip()
            if not text:
                # Intentar sin idioma especificado
                result = model.transcribe(audio_file, verbose=False)
                text = result["text"].strip()

            if text:
                return {
                    "text": text,
                    "language": result.get("language", language),
                    "transcription_time": 0  # No medimos tiempo para mantenerlo simple
                }
        except Exception:
            pass
        return None

    # Iniciar grabación
    print("Grabando... Presiona Enter para detener")

    stream = start_recording()
    if not stream:
        print("Error: No se pudo iniciar la grabación")
        print("Usa 'voice start-debug' para información detallada")
        return

    try:
        input()
        print("Deteniendo grabación...")

        # Detener y guardar
        audio_file = stop_recording_and_save(stream)
        if not audio_file:
            print("Error: No se pudo guardar el audio")
            return

        print("Realizando transcripción...")

        # Transcribir
        result = transcribe_clean(audio_file)

        if result and result["text"]:
            print(f"Idioma: {result['language']}")
            print()
            print("Transcripción:")
            print(result["text"])

            # Copiar al portapapeles
            if CLIPBOARD_AVAILABLE:
                try:
                    import pyperclip
                    pyperclip.copy(result["text"])
                    print()
                    print("Texto copiado al portapapeles")
                except:
                    pass
        else:
            print("Error: No se pudo transcribir el audio")
            print("Usa 'voice start-debug' para diagnóstico detallado")

    except KeyboardInterrupt:
        print("\nCancelado por el usuario")
        recording = False
        if stream:
            stream.stop()
            stream.close()

